import java.util.*;
class CountOccurrences<T> {
    public int count(List<T> list, T element) {
        int count = 0;
        for (T item : list) {
            if (item.equals(element)) {
                count++;
            }
        }
        return count;
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        List<Integer> numbers = new ArrayList<>();
        System.out.print("Enter number of elements: ");
        int n = sc.nextInt();
        System.out.println("Enter elements:");
        for (int i = 0; i < n; i++) {
            numbers.add(sc.nextInt());
        }
        System.out.print("Enter element to count: ");
        int element = sc.nextInt();
        CountOccurrences<Integer> obj = new CountOccurrences<>();
        System.out.println("Count = " + obj.count(numbers, element));
    }
}
